<Application x:Class="AICompanion.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <!--
        Application-level XAML configuration for AI Companion.
        
        This file defines application-wide resources including styles, brushes,
        and templates that maintain visual consistency across all windows and
        controls. The design follows modern Windows 11 aesthetics with rounded
        corners, subtle shadows, and a purple/blue gradient color scheme.
        
        The application starts with MainWindow.xaml which hosts the companion
        avatar and provides the primary voice interaction interface.
    -->
    <Application.Resources>
        <ResourceDictionary>
            
            <!-- Primary color palette based on the IBM and accessibility-focused design -->
            <Color x:Key="PrimaryColor">#0F766E</Color>
            <Color x:Key="SecondaryColor">#14B8A6</Color>
            <Color x:Key="BackgroundColor">#F3F7F6</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="TextPrimaryColor">#102A26</Color>
            <Color x:Key="TextSecondaryColor">#4B5B58</Color>
            <Color x:Key="SuccessColor">#22C55E</Color>
            <Color x:Key="ErrorColor">#E5484D</Color>
            <Color x:Key="WarningColor">#F59E0B</Color>

            <FontFamily x:Key="AppFont">Bahnschrift</FontFamily>
            
            <!-- Gradient brushes for buttons and accent elements -->
            <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                <GradientStop Color="{StaticResource SecondaryColor}" Offset="1"/>
            </LinearGradientBrush>
            
            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

            <!-- Theme-aware panel backgrounds -->
            <SolidColorBrush x:Key="AvatarPanelBrush" Color="#E7F5F3"/>
            <SolidColorBrush x:Key="CardPanelBrush" Color="#ECF8F6"/>
            <SolidColorBrush x:Key="InputPanelBrush" Color="#F5FBFA"/>
            <SolidColorBrush x:Key="LogPanelBrush" Color="#F7FBFA"/>
            <SolidColorBrush x:Key="LogHeaderBrush" Color="#ECF8F6"/>
            <SolidColorBrush x:Key="StatusPanelBrush" Color="#EEF2F1"/>
            <SolidColorBrush x:Key="StatusBorderBrush" Color="#D1E0DC"/>
            <SolidColorBrush x:Key="InputBorderBrush" Color="#D7E6E3"/>
            <SolidColorBrush x:Key="LogBorderBrush" Color="#DDEAE7"/>
            <SolidColorBrush x:Key="CardBorderBrush" Color="#D1E8E2"/>
            
            <!-- Base button style with rounded corners and hover effects -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource PrimaryGradientBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Padding" Value="20,12"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.9"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <!-- Text styles for consistent typography -->
            <Style x:Key="HeadingStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            </Style>

            <Style x:Key="BodyStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <!-- Card style for content containers -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10"
                                          ShadowDepth="2"
                                          Opacity="0.1"
                                          Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Quick command button style -->
            <Style x:Key="QuickCommandStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource CardPanelBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Margin" Value="3"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="15"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
