<UserControl x:Class="AICompanion.Desktop.Controls.AvatarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="200" Height="200">
    <!--
        AvatarControl provides the animated companion character display.
        
        The avatar uses vector graphics for scalability and smooth animations.
        Different emotional states are represented through eye shapes, mouth
        positions, and subtle color changes. Animations are triggered by
        binding to the CurrentEmotion property.
        
        Supported emotions:
        - Neutral: Default relaxed expression
        - Listening: Alert with raised eyebrows
        - Thinking: Eyes looking up, processing indicator
        - Speaking: Animated mouth movements
        - Happy: Smile with curved eyes
        - Confused: Tilted head, raised eyebrow
    -->
    
    <UserControl.Resources>
        <!-- Breathing animation for idle state -->
        <Storyboard x:Key="BreathingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation 
                Storyboard.TargetName="AvatarBody"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                From="1.0" To="1.02" Duration="0:0:2"
                AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Listening pulse animation -->
        <Storyboard x:Key="ListeningAnimation" RepeatBehavior="Forever">
            <DoubleAnimation 
                Storyboard.TargetName="ListeningIndicator"
                Storyboard.TargetProperty="Opacity"
                From="0.5" To="1.0" Duration="0:0:0.5"
                AutoReverse="True"/>
        </Storyboard>
        
        <!-- Thinking spinner animation -->
        <Storyboard x:Key="ThinkingAnimation" RepeatBehavior="Forever">
            <DoubleAnimation 
                Storyboard.TargetName="ThinkingSpinner"
                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                From="0" To="360" Duration="0:0:1"/>
        </Storyboard>
    </UserControl.Resources>
    
    <Grid x:Name="AvatarContainer">
        <!-- Main avatar body -->
        <Ellipse x:Name="AvatarBody" 
                 Width="180" Height="180"
                 Fill="{StaticResource PrimaryGradientBrush}">
            <Ellipse.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" CenterX="90" CenterY="90"/>
            </Ellipse.RenderTransform>
            <Ellipse.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
            </Ellipse.Effect>
        </Ellipse>
        
        <!-- Face container -->
        <Canvas Width="180" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Left eye -->
            <Ellipse x:Name="LeftEye" 
                     Canvas.Left="45" Canvas.Top="60"
                     Width="28" Height="35" 
                     Fill="White"/>
            <Ellipse x:Name="LeftPupil"
                     Canvas.Left="54" Canvas.Top="72"
                     Width="12" Height="15"
                     Fill="#1D1D1F"/>
            
            <!-- Right eye -->
            <Ellipse x:Name="RightEye"
                     Canvas.Left="107" Canvas.Top="60"
                     Width="28" Height="35"
                     Fill="White"/>
            <Ellipse x:Name="RightPupil"
                     Canvas.Left="116" Canvas.Top="72"
                     Width="12" Height="15"
                     Fill="#1D1D1F"/>
            
            <!-- Mouth -->
            <Path x:Name="Mouth"
                  Stroke="White" StrokeThickness="5"
                  Data="M 60,125 Q 90,145 120,125"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"/>
        </Canvas>
        
        <!-- Listening indicator (microphone glow) -->
        <Ellipse x:Name="ListeningIndicator"
                 Width="30" Height="30"
                 Fill="#34C759"
                 Opacity="0"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,10"/>
        
        <!-- Thinking spinner -->
        <Ellipse x:Name="ThinkingSpinner"
                 Width="40" Height="40"
                 Stroke="#667EEA"
                 StrokeThickness="4"
                 StrokeDashArray="2,2"
                 Opacity="0"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Right"
                 Margin="0,10,10,0">
            <Ellipse.RenderTransform>
                <RotateTransform Angle="0" CenterX="20" CenterY="20"/>
            </Ellipse.RenderTransform>
        </Ellipse>
    </Grid>
</UserControl>
