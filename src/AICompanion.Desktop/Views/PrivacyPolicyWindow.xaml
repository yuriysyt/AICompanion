<Window x:Class="AICompanion.Desktop.Views.PrivacyPolicyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AI Companion - Privacy Policy"
        Height="620"
        Width="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border CornerRadius="15"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="5"
                              Opacity="0.3"
                              Color="{StaticResource PrimaryColor}"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryGradientBrush}"
                    CornerRadius="13,13,0,0"
                    Padding="20,15">
                <StackPanel>
                    <TextBlock Text="Privacy Policy"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Please read before using AI Companion"
                               FontSize="12"
                               Foreground="White"
                               Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Policy Text -->
            <ScrollViewer Grid.Row="1"
                          Margin="0"
                          Padding="30,20,30,10"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Data Collection &amp; Storage"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,14"
                               LineHeight="20">
                        AI Companion stores your conversation history, settings, and credentials in an
                        encrypted SQLite database located at %LOCALAPPDATA%\AICompanion on your local
                        machine. No data is transmitted to external servers without your explicit consent.
                    </TextBlock>

                    <TextBlock Text="Voice Processing"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,14"
                               LineHeight="20">
                        Voice commands are captured only when you activate the microphone. Audio is
                        processed locally and is not stored permanently — only the transcribed text is
                        retained for context within your session.
                    </TextBlock>

                    <TextBlock Text="AI Engine"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,14"
                               LineHeight="20">
                        Commands are processed by the IBM Granite 3.3-2B model running locally on
                        your machine. Before being sent to the model, input is sanitized to remove
                        file system paths and other machine-specific identifiers.
                    </TextBlock>

                    <TextBlock Text="Security"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,14"
                               LineHeight="20">
                        Passwords are hashed using PBKDF2-SHA256 with a unique salt per user.
                        API keys are encrypted with Windows DPAPI. Sensitive conversation data is
                        encrypted at rest using AES-256.
                    </TextBlock>

                    <TextBlock Text="Your Rights"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,14"
                               LineHeight="20">
                        You may delete your account and all associated data at any time through
                        Settings. By clicking Accept you confirm that you have read and agree to
                        these terms.
                    </TextBlock>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource StatusBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="30,15">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Decline"
                            Width="110"
                            Height="36"
                            Margin="0,0,12,0"
                            Click="Decline_Click"/>
                    <Button Content="Accept"
                            Width="110"
                            Height="36"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Accept_Click"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
