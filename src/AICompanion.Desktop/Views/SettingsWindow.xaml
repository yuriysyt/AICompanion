<Window x:Class="AICompanion.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings - AI Companion"
        Height="550"
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryGradientBrush}" Padding="20,15">
            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <TextBlock Text="Configure voice engines, dictation, security, and appearance"
                           FontSize="12"
                           Foreground="#CCFFFFFF"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Margin="15,10,15,10"
                    Background="Transparent"
                    BorderThickness="0">

            <!-- Voice Tab -->
            <TabItem Header="Voice">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                    <StackPanel Margin="10">

                        <!-- Voice Engine - ElevenLabs Only -->
                        <TextBlock Text="Speech Recognition Engine"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="ElevenLabs Voice Engine"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Cloud-based Speech-to-Text and Text-to-Speech with high accuracy."
                                           FontSize="11" Foreground="Gray" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- ElevenLabs Settings -->
                        <TextBlock Text="ElevenLabs Configuration"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="API Key:" VerticalAlignment="Center"/>
                                <TextBox x:Name="ElevenLabsApiKeyBox" Grid.Row="0" Grid.Column="1"
                                         Margin="0,0,0,10" Padding="8,6"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Voice ID:" VerticalAlignment="Center"/>
                                <TextBox x:Name="ElevenLabsVoiceIdBox" Grid.Row="1" Grid.Column="1"
                                         Margin="0,0,0,10" Padding="8,6"/>

                                <CheckBox x:Name="ElevenLabsTTSEnabled" Grid.Row="2" Grid.ColumnSpan="2"
                                          Content="Enable Text-to-Speech" IsChecked="True" Margin="0,0,0,5"/>
                                <CheckBox x:Name="ElevenLabsSTTEnabled" Grid.Row="3" Grid.ColumnSpan="2"
                                          Content="Enable Speech-to-Text" IsChecked="True"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Dictation Tab -->
            <TabItem Header="Dictation">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                    <StackPanel Margin="10">

                        <TextBlock Text="Dictation Settings"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <CheckBox x:Name="AutoDictationCheck"
                                          Content="Auto-detect Word/Notepad and enable dictation"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <CheckBox x:Name="AutoPunctuationCheck"
                                          Content="Auto-punctuation (add periods at pauses)"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <CheckBox x:Name="AutoCapitalizationCheck"
                                          Content="Auto-capitalize sentences"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <TextBlock Text="Target Applications:"
                                           FontWeight="SemiBold"
                                           Margin="0,10,0,8"/>

                                <CheckBox x:Name="TargetWordCheck"
                                          Content="Microsoft Word"
                                          IsChecked="True"
                                          Margin="15,0,0,5"/>
                                <CheckBox x:Name="TargetNotepadCheck"
                                          Content="Notepad"
                                          IsChecked="True"
                                          Margin="15,0,0,5"/>
                                <CheckBox x:Name="TargetVSCodeCheck"
                                          Content="Visual Studio Code"
                                          IsChecked="False"
                                          Margin="15,0,0,5"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Voice Commands for Dictation"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Say 'delete word' - Remove last word" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="Say 'new line' - Insert line break" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="Say 'new paragraph' - Insert paragraph" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="Say 'period/comma/question' - Insert punctuation" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock Text="Say 'bold/italic/underline' - Format text" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Security Tab -->
            <TabItem Header="Security">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                    <StackPanel Margin="10">

                        <TextBlock Text="Authentication"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <CheckBox x:Name="RequireLoginCheck"
                                          Content="Require login at startup"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <CheckBox x:Name="RememberMeCheck"
                                          Content="Remember me for 7 days"
                                          IsChecked="True"
                                          Margin="0,0,0,15"/>

                                <Button Content="Change Password"
                                        Width="150"
                                        HorizontalAlignment="Left"
                                        Click="ChangePassword_Click"
                                        Style="{DynamicResource QuickCommandStyle}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Security Code"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <CheckBox x:Name="RequireSecurityCodeCheck"
                                          Content="Require security code for sensitive operations"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Code timeout:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="SecurityCodeTimeoutCombo" Width="120">
                                        <ComboBoxItem Content="30 seconds" Tag="30"/>
                                        <ComboBoxItem Content="1 minute" Tag="60" IsSelected="True"/>
                                        <ComboBoxItem Content="2 minutes" Tag="120"/>
                                        <ComboBoxItem Content="5 minutes" Tag="300"/>
                                    </ComboBox>
                                </StackPanel>

                                <TextBlock Text="Sensitive operations: Delete files, System commands, Clear history"
                                           FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Session"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Auto-lock after inactivity:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="AutoLockCombo" Width="120">
                                        <ComboBoxItem Content="Never" Tag="0"/>
                                        <ComboBoxItem Content="5 minutes" Tag="5"/>
                                        <ComboBoxItem Content="15 minutes" Tag="15" IsSelected="True"/>
                                        <ComboBoxItem Content="30 minutes" Tag="30"/>
                                    </ComboBox>
                                </StackPanel>

                                <Button Content="Lock Now"
                                        Width="100"
                                        HorizontalAlignment="Left"
                                        Click="LockNow_Click"
                                        Style="{DynamicResource QuickCommandStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Database Tab -->
            <TabItem Header="Database">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                    <StackPanel Margin="10">

                        <TextBlock Text="Database Location"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="DatabasePathText"
                                           Text="Path: %LOCALAPPDATA%\AICompanion\data.db"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Open Folder"
                                            Click="OpenDatabaseFolder_Click"
                                            Style="{DynamicResource QuickCommandStyle}"
                                            Margin="0,0,10,0"/>
                                    <Button Content="Backup Database"
                                            Click="BackupDatabase_Click"
                                            Style="{DynamicResource QuickCommandStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Command History"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="HistoryCountText"
                                           Text="Total commands: 0"
                                           Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Keep history for:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="HistoryRetentionCombo" Width="120">
                                        <ComboBoxItem Content="7 days" Tag="7"/>
                                        <ComboBoxItem Content="30 days" Tag="30" IsSelected="True"/>
                                        <ComboBoxItem Content="90 days" Tag="90"/>
                                        <ComboBoxItem Content="Forever" Tag="0"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="View History"
                                            Click="ViewHistory_Click"
                                            Style="{StaticResource QuickCommandStyle}"
                                            Margin="0,0,10,0"/>
                                    <Button Content="Clear History"
                                            Click="ClearHistory_Click"
                                            Style="{StaticResource QuickCommandStyle}"
                                            Foreground="#E5484D"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Data Export"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export to JSON"
                                        Click="ExportJson_Click"
                                        Style="{DynamicResource QuickCommandStyle}"
                                        Margin="0,0,10,0"/>
                                <Button Content="Export to CSV"
                                        Click="ExportCsv_Click"
                                        Style="{DynamicResource QuickCommandStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Appearance Tab -->
            <TabItem Header="Appearance">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                    <StackPanel Margin="10">

                        <TextBlock Text="Theme"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <RadioButton x:Name="ThemeLight"
                                             Content="Light"
                                             GroupName="Theme"
                                             IsChecked="True"
                                             Margin="0,0,0,8"/>
                                <RadioButton x:Name="ThemeDark"
                                             Content="Dark"
                                             GroupName="Theme"
                                             Margin="0,0,0,8"/>
                                <RadioButton x:Name="ThemeSystem"
                                             Content="Follow System"
                                             GroupName="Theme"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Window"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <CheckBox x:Name="AlwaysOnTopCheck"
                                          Content="Always on top"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <CheckBox x:Name="MinimizeToTrayCheck"
                                          Content="Minimize to system tray"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <CheckBox x:Name="StartMinimizedCheck"
                                          Content="Start minimized"
                                          IsChecked="False"
                                          Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Opacity:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Slider x:Name="OpacitySlider"
                                            Width="150"
                                            Minimum="0.5"
                                            Maximum="1.0"
                                            Value="1.0"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True"/>
                                    <TextBlock x:Name="OpacityValueText" Text="100%" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Notifications"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,5,0,10"/>

                        <Border Background="White" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <CheckBox x:Name="ShowToastCheck"
                                          Content="Show toast notifications"
                                          IsChecked="True"
                                          Margin="0,0,0,10"/>

                                <CheckBox x:Name="PlaySoundsCheck"
                                          Content="Play sounds for actions"
                                          IsChecked="True"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Test Connection"
                        Click="TestConnection_Click"
                        Style="{DynamicResource QuickCommandStyle}"
                        Margin="0,0,10,0"/>
                <Button Content="Cancel"
                        Click="Cancel_Click"
                        Width="80"
                        Padding="10,8"
                        Background="#E0E0E0"
                        Margin="0,0,10,0"/>
                <Button Content="Save"
                        Click="Save_Click"
                        Width="100"
                        Padding="10,8"
                        Style="{DynamicResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
