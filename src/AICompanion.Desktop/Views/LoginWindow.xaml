<Window x:Class="AICompanion.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AI Companion - Login"
        Height="680"
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border CornerRadius="15"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="5"
                              Opacity="0.3"
                              Color="{StaticResource PrimaryColor}"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryGradientBrush}"
                    CornerRadius="13,13,0,0"
                    Padding="20,15"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="40" Height="40" Fill="White" Opacity="0.2"/>
                            <TextBlock Text="AI Companion"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Content="X"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="30" Height="30"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            Click="CloseButton_Click"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="30,20,30,30">
                <!-- Login Panel -->
                <StackPanel x:Name="LoginPanel">
                    <TextBlock Text="Welcome Back"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Sign in to continue"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,25"/>

                    <!-- Username -->
                    <TextBlock Text="Username or Email"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="UsernameBox"
                             Padding="12,10"
                             FontSize="14"
                             Margin="0,0,0,15"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Padding="12,10"
                                 FontSize="14"
                                 Margin="0,0,0,10"/>

                    <!-- Remember Me & Forgot -->
                    <Grid Margin="0,0,0,20">
                        <CheckBox x:Name="RememberMeCheck"
                                  Content="Remember me"
                                  HorizontalAlignment="Left"/>
                        <TextBlock HorizontalAlignment="Right">
                            <Hyperlink x:Name="ForgotPasswordLink"
                                       Click="ForgotPassword_Click"
                                       Foreground="{StaticResource PrimaryBrush}">
                                Forgot password?
                            </Hyperlink>
                        </TextBlock>
                    </Grid>

                    <!-- Error Message -->
                    <TextBlock x:Name="ErrorMessage"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="Collapsed"/>

                    <!-- Login Button -->
                    <Button Content="Sign In"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Login_Click"
                            Margin="0,0,0,15"/>

                    <!-- Divider -->
                    <Grid Margin="0,5,0,15">
                        <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="or"
                                   Background="White"
                                   Padding="10,0"
                                   HorizontalAlignment="Center"
                                   Foreground="Gray"/>
                    </Grid>

                    <!-- Register Link -->
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="Don't have an account? "/>
                        <Hyperlink Click="ShowRegister_Click"
                                   Foreground="{StaticResource PrimaryBrush}">
                            Create one
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Register Panel -->
                <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                    <TextBlock Text="Create Account"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Sign up to get started"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Username -->
                    <TextBlock Text="Username"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="RegisterUsernameBox"
                             Padding="12,10"
                             FontSize="14"
                             Margin="0,0,0,12"/>

                    <!-- Email -->
                    <TextBlock Text="Email"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="RegisterEmailBox"
                             Padding="12,10"
                             FontSize="14"
                             Margin="0,0,0,12"/>

                    <!-- Password -->
                    <TextBlock Text="Password"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="RegisterPasswordBox"
                                 Padding="12,10"
                                 FontSize="14"
                                 Margin="0,0,0,12"/>

                    <!-- Confirm Password -->
                    <TextBlock Text="Confirm Password"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="RegisterConfirmPasswordBox"
                                 Padding="12,10"
                                 FontSize="14"
                                 Margin="0,0,0,12"/>

                    <!-- Security PIN -->
                    <TextBlock Text="Security PIN (4-6 digits)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="RegisterPinBox"
                                 MaxLength="6"
                                 Padding="12,10"
                                 FontSize="14"
                                 Margin="0,0,0,4"/>
                    <TextBlock Text="You will need this PIN to confirm sensitive operations"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,15"/>

                    <!-- Error Message -->
                    <TextBlock x:Name="RegisterErrorMessage"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="Collapsed"/>

                    <!-- Register Button -->
                    <Button Content="Create Account"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="Register_Click"
                            Margin="0,0,0,15"/>

                    <!-- Back to Login -->
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="Already have an account? "/>
                        <Hyperlink Click="ShowLogin_Click"
                                   Foreground="{StaticResource PrimaryBrush}">
                            Sign in
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Security Code Panel -->
                <StackPanel x:Name="SecurityCodePanel" Visibility="Collapsed">
                    <TextBlock Text="Security Verification"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,5"/>

                    <TextBlock Text="Enter the 6-digit code"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <!-- Code Display -->
                    <Border Background="#E7F5F3"
                            CornerRadius="10"
                            Padding="20"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="SecurityCodeDisplay"
                                   Text="123456"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontFamily="Consolas"/>
                    </Border>

                    <!-- Timer -->
                    <TextBlock x:Name="CodeTimerText"
                               Text="Code expires in: 60 seconds"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Code Input -->
                    <TextBox x:Name="SecurityCodeInput"
                             MaxLength="6"
                             Padding="15,12"
                             FontSize="20"
                             FontFamily="Consolas"
                             TextAlignment="Center"
                             Margin="0,0,0,15"/>

                    <!-- Verify Button -->
                    <Button Content="Verify Code"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="VerifyCode_Click"
                            Margin="0,0,0,15"/>

                    <TextBlock Text="Say the code aloud or type it"
                               FontSize="11"
                               Foreground="Gray"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
